rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Menu items - TEMPORARILY OPEN FOR TESTING - should require admin in production
    match /menu/{menuId} {
      allow read: if true;
      allow create, update, delete: if true; // TEMP: allow all for testing
      // Original: allow create, update, delete: if request.auth != null && request.auth.token.admin == true;
    }

    // Users owned data (customers)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Orders: customers can create; admins can read/update
    match /orders/{orderId} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
      allow create: if request.auth != null;
    }

    // Reservations: customers can create; admins can manage
    match /reservations/{resId} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
      allow create: if request.auth != null;
    }

    // Analytics: admin only
    match /analytics/{doc=**} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow write: if false;
    }
  }
}
